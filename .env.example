# ==========================================
# LIVEKIT CLOUD CREDENTIALS
# ==========================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# AI MODEL KEYS
# ==========================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Connection pool size (keep max at 20 for Supabase free tier,
# increase to 40 for Supabase pro tier)
DB_POOL_MIN=2
DB_POOL_MAX=20

# ==========================================
# VOBIZ SIP TRUNK CONFIGURATION
# ==========================================
VOBIZ_SIP_DOMAIN=your-domain.sip.vobiz.ai
VOBIZ_USERNAME=your_vobiz_username
VOBIZ_PASSWORD=your_vobiz_password
VOBIZ_OUTBOUND_NUMBER=+911234567890
DEFAULT_TRANSFER_NUMBER=+911234567890
SIP_TRUNK_ID=ST_xxxxxxxx
OUTBOUND_TRUNK_ID=ST_xxxxxxxx

# ==========================================
# OPTIONAL PROVIDER SETTINGS
# ==========================================
TTS_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_PROVIDER=openai
TEMPERATURE=0.4
MAX_TOKENS=400
STT_LANGUAGE=unknown
STT_MIN_ENDPOINTING_DELAY=0.5
TTS_LANGUAGE=hi-IN
TTS_VOICE=rohan

# ==========================================
# CAL.COM / TELEGRAM
# ==========================================
CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxx
CAL_EVENT_TYPE_ID=123456
TELEGRAM_BOT_TOKEN=xxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
TELEGRAM_CHAT_ID=1234567890

# ==========================================
# CLOUD STORAGE
# ==========================================
R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=call-recordings
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
PUBLIC_BASE_URL=https://your-domain.com

# ==========================================
# WHATSAPP
# ==========================================
EVOLUTION_API_URL=https://your-evolution-api.com

# ==========================================
# OTHER OPTIONALS
# ==========================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
