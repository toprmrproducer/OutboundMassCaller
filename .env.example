# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Speech providers
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_POOL_MIN=2
DB_POOL_MAX=20

# Local dev (docker-compose)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/outboundcaller
REDIS_URL=redis://redis:6379/0

# SIP / Telephony
VOBIZ_SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+911234567890
DEFAULT_TRANSFER_NUMBER=+911234567890
SIP_TRUNK_ID=ST_xxxxxxxx
OUTBOUND_TRUNK_ID=ST_xxxxxxxx

# Runtime model preferences
LLM_MODEL=gpt-4.1-mini
LLM_PROVIDER=openai
TEMPERATURE=0.4
MAX_TOKENS=400
STT_LANGUAGE=unknown
STT_MIN_ENDPOINTING_DELAY=0.5
TTS_PROVIDER=sarvam
TTS_LANGUAGE=hi-IN
TTS_VOICE=rohan

# Cloudflare R2
R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=call-recordings
R2_PUBLIC_URL=https://public-bucket-url.example.com
PUBLIC_BASE_URL=https://your-domain.com

# WhatsApp / Evolution API
EVOLUTION_API_URL=https://your-evolution-api.com

# Logging
LOG_FORMAT=json
LOG_LEVEL=INFO

# Security
AUTH_ENABLED=false
PII_MASKING_ENABLED=false

# Optional integrations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
HUBSPOT_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
SLACK_WEBHOOK_URL=
NUMVERIFY_API_KEY=
GROQ_API_KEY=

# Optional legacy vars
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
